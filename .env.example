# .env.example
# Скопируйте этот файл в .env и заполните значениями
# НЕ КОММИТЬТЕ ФАЙЛ .env В GIT!

# API ключ для LLM (OpenAI, Anthropic, etc.)
PRIZOLOV_API_KEY=your_api_key_here

# Путь к файлу памяти
PRIZOLOV_MEMORY_PATH=data/memory.json

# Уровень логирования: DEBUG, INFO, WARNING, ERROR, CRITICAL
PRIZOLOV_LOG_LEVEL=INFO

# Путь к файлу логов (оставьте пустым для вывода только в консоль)
PRIZOLOV_LOG_FILE=prizolov.log

# Уровень безопасности: low, medium, high
PRIZOLOV_SECURITY_LEVEL=high

# Максимальное количество попыток выполнения
PRIZOLOV_MAX_RETRIES=3

# Таймаут запросов в секундах
PRIZOLOV_TIMEOUT=30
