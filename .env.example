# .env.example
# Скопируйте этот файл в .env и заполните значениями
# НЕ КОММИТЬТЕ ФАЙЛ .env В GIT!

# =============================================================================
# API И ИНТЕГРАЦИИ
# =============================================================================

# API ключ для LLM (OpenAI, Anthropic, или другой провайдер)
PRIZOLOV_API_KEY=your_api_key_here

# =============================================================================
# ПАМЯТЬ И ХРАНЕНИЕ
# =============================================================================

# Тип хранилища памяти: in_memory, json, sqlite
# in_memory = быстро, данные теряются после перезапуска
# json = просто, данные сохраняются в JSON файл
# sqlite = надёжно, данные сохраняются в SQLite БД
PRIZOLOV_MEMORY_BACKEND=json

# Путь к файлу памяти (JSON) или базе данных (SQLite)
PRIZOLOV_MEMORY_PATH=data/memory.json

# =============================================================================
# ЛОГИРОВАНИЕ
# =============================================================================

# Уровень логирования: DEBUG, INFO, WARNING, ERROR, CRITICAL
PRIZOLOV_LOG_LEVEL=INFO

# Путь к файлу логов (оставьте пустым для вывода только в консоль)
PRIZOLOV_LOG_FILE=prizolov.log

# =============================================================================
# БЕЗОПАСНОСТЬ
# =============================================================================

# Уровень безопасности: low, medium, high
PRIZOLOV_SECURITY_LEVEL=high

# =============================================================================
# ПОВЕДЕНИЕ СИСТЕМЫ
# =============================================================================

# Максимальное количество попыток выполнения задачи при ошибке
PRIZOLOV_MAX_RETRIES=3

# Таймаут запросов в секундах (для сетевых операций)
PRIZOLOV_TIMEOUT=30
